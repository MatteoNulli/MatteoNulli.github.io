<style>
  .latest-post-thumb-wrap {
    display: block;
    width: 100%;
  }

  .latest-post-thumb {
    width: 100%;
    max-width: 320px;
    height: auto;
    max-height: 210px;
    object-fit: contain;
    object-position: center;
    border-radius: 10px;
    display: block;
  }


  .latest-post-desc {
    margin: 0.45rem 0 0.45rem 0;
    opacity: 0.85;
    font-size: 0.98rem;
    line-height: 1.4;
  }

  .latest-post-tags {
    margin: 0.1rem 0 0.55rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .latest-post-tag {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    font-size: 0.78rem;
    line-height: 1.2;
    background: rgba(127, 127, 127, 0.15);
  }

  .latest-post-links {
    margin: 0.1rem 0 0.55rem 0;
    line-height: 1;
  }

  .latest-post-links a {
    margin-right: 0.6rem;
    text-decoration: none;
  }

  .latest-post-links i {
    font-size: 1.25em;
  }

  .latest-post-date {
    font-size: 0.9rem;
    margin-top: 0.15rem;
  }
</style>

<div class="news">
  {% if site.latest_posts != blank %}
    {% assign latest_posts_size = site.posts | size %}
    <div
      class="table-responsive"
      {% if site.latest_posts.scrollable and latest_posts_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign latest_posts = site.posts %}
        {% if site.latest_posts.limit %}
          {% assign latest_posts_limit = site.latest_posts.limit %}
        {% else %}
          {% assign latest_posts_limit = latest_posts_size %}
        {% endif %}

        {% for item in latest_posts limit: latest_posts_limit %}
          {% assign post_image = item.image | default: item.thumbnail | default: '/assets/img/default-post.jpg' %}
          {% assign post_desc = item.description | default: item.excerpt | strip_html | strip %}
          <tr>
            <td style="width: 350px; vertical-align: top;">
              <a class="latest-post-thumb-wrap" href="{{ item.url | relative_url }}">
                {% if post_image contains '://' %}
                  <img src="{{ post_image }}" alt="{{ item.title }}" class="latest-post-thumb">
                {% else %}
                  <img src="{{ post_image | relative_url }}" alt="{{ item.title }}" class="latest-post-thumb">
                {% endif %}
              </a>
            </td>

            <td style="vertical-align: top;">
              {% if item.redirect == blank %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% elsif item.redirect contains '://' %}
                <a class="news-title" href="{{ item.redirect }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
              {% else %}
                <a class="news-title" href="{{ item.redirect | relative_url }}">{{ item.title }}</a>
              {% endif %}

              {% if post_desc != blank %}
                <div class="latest-post-desc">{{ post_desc }}</div>
              {% endif %}

              {% if item.tags and item.tags.size > 0 %}
                <div class="latest-post-tags">
                  {% for tag in item.tags %}
                    <span class="latest-post-tag">{{ tag }}</span>
                  {% endfor %}
                </div>
              {% endif %}

              {% if item.community_article_url or item.blogpost_url or item.thesis_url or item.paper_url or item.code_url %}
                <div class="latest-post-links">
                  {% if item.community_article_url %}
                    <a href="{{ item.community_article_url }}" title="Community Article" target="_blank" rel="noopener noreferrer">
                      <i class="fa-brands fa-hugging-face"></i>
                    </a>
                  {% endif %}
                  {% if item.blogpost_url %}
                    <a href="{{ item.blogpost_url }}" title="Blogpost" target="_blank" rel="noopener noreferrer">
                      <i class="fa-regular fa-newspaper"></i>
                    </a>
                  {% endif %}
                  {% if item.thesis_url %}
                    <a href="{{ item.thesis_url }}" title="Thesis" target="_blank" rel="noopener noreferrer">
                      <i class="fa-solid fa-graduation-cap"></i>
                    </a>
                  {% endif %}
                  {% if item.paper_url %}
                    <a href="{{ item.paper_url }}" title="Paper" target="_blank" rel="noopener noreferrer">
                      <i class="fa-solid fa-file-lines"></i>
                    </a>
                  {% endif %}
                  {% if item.code_url %}
                    <a href="{{ item.code_url }}" title="Code" target="_blank" rel="noopener noreferrer">
                      <i class="fa-brands fa-github"></i>
                    </a>
                  {% endif %}
                </div>
              {% endif %}

              <div class="text-muted latest-post-date">
                {{ item.date | date: '%b %d, %Y' }}
              </div>
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No posts so far...</p>
  {% endif %}
</div>