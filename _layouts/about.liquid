---
layout: default
---
<div class="post">

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    min-height: 82vh;      /* was 90vh */
    padding: 0.5rem 0 2rem;/* less top padding */
    margin-top: -1.5rem;   /* push name + image + socials up */
  }

  .hero-left { flex: 1 1 55%; }
  .hero-right { flex: 1 1 45%; display: flex; justify-content: flex-end; }

  .hero-title {
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--global-theme-color) !important;
    margin-bottom: 1rem;
  }

  .hero-blurb {
    font-size: 1.05rem;
    opacity: 0.8;
    max-width: 42rem;
    margin-bottom: 1.5rem;
  }

  .hero .hero-blurb a.text-primary {
    color: var(--global-theme-color) !important;
    text-decoration: none;
  }

  .hero .hero-blurb a.text-primary:hover {
    color: var(--global-hover-color) !important;
    text-decoration: underline;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .hero-socials { margin-top: 1rem; }
  .hero-socials a {
    font-size: 2.5rem;
  }

  .hero-img {
    width: min(360px, 80vw);
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    object-fit: cover;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
  }

  .hero-socials a[href^="mailto:"] {
    display: none !important;
  }
  
  .scroll-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    margin: 0.5rem 0 2rem; /* re-balance after moving hero up */
    opacity: 0.6;
  }

  .bored-link {
    display: inline-block;
    font-size: 0.6rem;
    color: var(--global-theme-color) !important;
    text-decoration: none;
    opacity: 1;
    transform: translate(22rem, -0.1rem);
    position: relative;
    z-index: 30;
    pointer-events: auto;
  }

  .bored-link-row {
    margin-top: -3.5rem;
    margin-bottom: 2rem;
    text-align: center;
    position: relative;
    z-index: 25;
    pointer-events: none;
  }

  .bored-link:hover,
  .bored-link:focus {
    color: var(--global-hover-color) !important;
    text-decoration: underline;
    opacity: 1;
  }

  .bored-link {
    pointer-events: auto;
  }

  #about {
    scroll-margin-top: 5rem;
  }

  .contact-cta .btn.btn-primary {
    background-color: var(--global-theme-color) !important;
    border-color: var(--global-theme-color) !important;
    color: #fff !important;
  }

  .contact-cta .btn.btn-primary:hover,
  .contact-cta .btn.btn-primary:focus {
    background-color: var(--global-hover-color) !important;
    border-color: var(--global-hover-color) !important;
    color: #fff !important;
  }

  .social .contact-icons a {
    color: var(--global-theme-color) !important;
  }

  .social .contact-icons,
  .social .contact-icons a:visited,
  .social .contact-icons i,
  .social .contact-icons i::before,
  .social .contact-icons svg,
  .social .contact-icons svg * {
    color: var(--global-theme-color) !important;
    fill: currentColor !important;
    stroke: currentColor !important;
  }

  .social .contact-icons a:hover,
  .social .contact-icons a:hover i,
  .social .contact-icons a:hover i::before,
  .social .contact-icons a:hover svg,
  .social .contact-icons a:hover svg *,
  .social .contact-icons a:focus,
  .social .contact-icons a:focus i,
  .social .contact-icons a:focus i::before,
  .social .contact-icons a:focus svg,
  .social .contact-icons a:focus svg * {
    color: var(--global-hover-color) !important;
    fill: currentColor !important;
    stroke: currentColor !important;
  }

  .contact-section {
    margin-top: 2rem;
  }

  .contact-section h2 {
    margin-bottom: 1rem;
  }

  .contact-section .contact-cta {
    margin-bottom: 1rem;
  }

  .contact-section .contact-cta p {
    margin-bottom: 1rem;
  }

  .contact-section .contact-cta .btn.btn-primary {
    margin-top: 1.25rem;
    margin-bottom: 1rem;
  }

  .contact-section .contact-icons {
    margin-top: 0.5rem;
  }
  
  .contact-cta .btn.btn-primary {
    background-color: var(--global-theme-color) !important;
    border-color: var(--global-theme-color) !important;
    color: #fff !important;
    border-radius: 999px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.28);
  }

  .contact-cta .btn.btn-primary:hover,
  .contact-cta .btn.btn-primary:focus {
    background-color: var(--global-hover-color) !important;
    border-color: var(--global-hover-color) !important;
    color: #fff !important;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.34);
  }

  .contact-section .contact-icons a[href^="mailto:"] {
    display: none !important;
  }


  .section-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-heading-row h2 {
    margin: 0;
  }

  .read-more-link {
    margin-left: auto;
    padding: 0;
    border-radius: 0;
    background: transparent;
    color: var(--global-hover-color) !important;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    line-height: 1;
  }

  .read-more-link span {
    color: currentColor !important;
  }

  .read-more-link:hover,
  .read-more-link:focus {
    background: transparent;
    color: var(--global-hover-color) !important;
    text-decoration: underline;
  }


  @media (max-width: 900px) {
    .hero { flex-direction: column-reverse; text-align: center; margin-top: -0.75rem; min-height: auto; }
    .hero-right { justify-content: center; }
    .hero-actions { justify-content: center; }
  }
</style>
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{site.max_width}}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if site.latest_posts.enabled %}
      <div class="section-heading-row">
        <h2>
          <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest blogpost</a>
        </h2>
        <a class="read-more-link" href="{{ '/blog/' | relative_url }}">
          read more <span aria-hidden="true">→</span>
        </a>
      </div>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Contact -->
    {% if page.social %}
      <section id="contact" class="contact-section">
        <h2>contact</h2>

        <div class="social">
          <div class="contact-cta mt-3">
            <h3>Let&#39;s Work Together</h3>
            <p>Whether you have a question, a project in mind, or just want to talk</p>
            {% if site.email %}
              <a class="btn btn-primary" href="mailto:{{ site.email }}">Say Hi</a>
            {% endif %}
          </div>

          <div class="contact-icons">{% include social.liquid %}</div>

          <div class="contact-note">{{ site.contact_note }}</div>
        </div>
      </section>
    {% endif %}
  </article>
</div>
